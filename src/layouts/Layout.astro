---
export interface Props {
  title?: string;
  description?: string;
}

const SITE_URL = Astro.site ? Astro.site.toString().replace(/\/$/, '') : 'https://pagensmedia.com.ar';

const { 
  title = "PagensMedia | Diseño Web Premium para Agencias y Empresas en LATAM",
  description = "Creamos sitios web que convierten visitantes en clientes. Especialistas en landing pages, web corporativa y admin panels para LATAM. Consulta gratis."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={`${SITE_URL}/`} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${SITE_URL}/`} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="PagensMedia" />
    <meta property="og:image" content={`${SITE_URL}/logo.jpg`} />
    <meta property="og:image:width" content="400" />
    <meta property="og:image:height" content="400" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE_URL}/logo.jpg`} />
    
    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <title>{title}</title>
    
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "PagensMedia",
        "url": SITE_URL,
        "logo": `${SITE_URL}/logo.jpg`,
        "description": "Agencia de diseño web especializada en sitios que generan resultados para agencias, hoteles, inmobiliarias y empresas de servicios en LATAM",
        "email": "pagensmedia@gmail.com",
        "sameAs": [
          "https://www.instagram.com/pagensmedia/"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+54-92235319564",
          "contactType": "sales",
          "availableLanguage": ["Spanish", "English"],
          "areaServed": "Latinoamérica"
        },
        "address": {
          "@type": "PostalAddress",
          "addressCountry": "AR",
          "areaServed": "Latinoamérica"
        }
      })} />
    
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "PagensMedia",
        "description": "Agencia de diseño web especializada en sitios que generan resultados",
        "url": SITE_URL,
        "logo": `${SITE_URL}/logo.jpg`,
        "areaServed": "Latinoamérica",
        "serviceType": ["Diseño Web", "Desarrollo Web", "Landing Pages", "Sitios Corporativos", "Admin Panels", "Rediseño Web"],
        "priceRange": "$$",
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "50",
          "bestRating": "5",
          "worstRating": "1"
        }
      })} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
