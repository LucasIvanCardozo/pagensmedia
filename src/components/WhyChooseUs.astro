---
import styles from './WhyChooseUs.module.css';

const differentiators = [
  {
    number: '01',
    title: 'Diseño con Propósito',
    description: 'No creamos sitios web solo porque sí. Cada diseño, cada color, cada botón tiene un objetivo: hacer crecer tu negocio. Medimos el éxito por tus resultados, no por lo bonito que se vea.',
    icon: 'target'
  },
  {
    number: '02',
    title: 'Comunicación Clara en Cada Etapa',
    description: 'Sabemos lo frustrante que es quedarse en la oscuridad. Por eso te mantenemos informado con actualizaciones semanales y acceso a ver el progreso en tiempo real. Sin sorpresas, sin retrasos ocultos.',
    icon: 'message'
  },
  {
    number: '03',
    title: 'Entendemos tu Mercado',
    description: 'Hemos trabajado con agencias, hoteles, inmobiliarias y empresas de servicios. Conocemos los desafíos específicos de tu industria y sabemos qué funciona para convertir visitantes en clientes.',
    icon: 'users'
  },
  {
    number: '04',
    title: 'Lo Último, Siempre',
    description: 'Usamos las tecnologías más actuales que garantizan velocidad, seguridad y escalabilidad. Tu sitio web estará construido para durar y crecer contigo, no para necesitar un rediseño en 6 meses.',
    icon: 'zap'
  },
  {
    number: '05',
    title: 'Estamos Aquí Después del Lanzamiento',
    description: 'El lanzamiento es solo el comienzo. Incluimos 30 días de soporte prioritario para asegurarnos de que todo funcione perfectamente. Y si necesitas ayuda después, seguimos aquí.',
    icon: 'shield'
  }
];
---

<section class={`section ${styles.whyChooseUs}`}>
  <div class={styles.container}>
    <div class={styles.sectionHeader}>
      <p class={styles.label}>¿Por Qué Elegir PagensMedia?</p>
      <h2 class={styles.title}>No somos solo otra agencia de diseño</h2>
    </div>
    
    <div class={styles.differentiators}>
      {differentiators.map((item, index) => (
        <div class={styles.differentiator}>
          <div class={styles.content}>
            <span class={styles.number}>{item.number}</span>
            <h3 class={styles.differentiatorTitle}>{item.title}</h3>
            <p class={styles.differentiatorDescription}>{item.description}</p>
          </div>
          <div class={styles.visual}>
            <div class={styles.iconCircle}>
              {item.icon === 'target' && (
                <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="10"/>
                  <circle cx="12" cy="12" r="6"/>
                  <circle cx="12" cy="12" r="2"/>
                </svg>
              )}
              {item.icon === 'message' && (
                <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                </svg>
              )}
              {item.icon === 'users' && (
                <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              )}
              {item.icon === 'zap' && (
                <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
              )}
              {item.icon === 'shield' && (
                <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
