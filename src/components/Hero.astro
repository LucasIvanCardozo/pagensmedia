---
import styles from './Hero.module.css';
---

<section class={styles.hero} id="inicio">
  <div class={styles.gradientBackground}></div>
  
  <div class={styles.container}>
    <span class={styles.label}>Agencia de Diseño Web Premium</span>
    
    <h1 class={styles.headline}>
      Diseño Web que <span>Convierte</span> Visitantes en Clientes
    </h1>
    
    <p class={styles.subheadline}>
      Creamos experiencias digitales premium para agencias, hoteles, inmobiliarias y empresas de servicios. Sitios web que no solo se ven increíbles, sino que generan resultados reales.
    </p>
    
    <div class={styles.ctaGroup}>
      <a href="#contacto" class={styles.primaryCta}>
        Agenda tu Consulta Gratis
      </a>
      <a href="#portafolio" class={styles.secondaryCta}>
        Ver Portafolio
      </a>
    </div>
    
    <p class={styles.microcopy}>Sin compromiso • Respuesta en 24h</p>
    
    <div class={styles.socialProof}>
      <span class={styles.rating}>
        <span class={styles.stars}>★★★★★</span> 4.9/5
      </span>
      <span class={styles.rating}>Más de 50 proyectos entregados</span>
      <span class={styles.rating}>Clientes en 8 países</span>
    </div>
  </div>
</section>
