---
import styles from './TrustStrip.module.css';
---

<section class={styles.trustStrip}>
  <div class={styles.container}>
    <div class={styles.benefits}>
      <div class={styles.benefit}>
        <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
        </svg>
        <span class={styles.text}>Entrega en 2-4 semanas</span>
      </div>
      
      <div class={styles.benefit}>
        <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 19l7-7 3 3-7 7-3-3z"/>
          <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
          <path d="M2 2l7.586 7.586"/>
          <circle cx="11" cy="11" r="2"/>
        </svg>
        <span class={styles.text}>Diseño 100% personalizado</span>
      </div>
      
      <div class={styles.benefit}>
        <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
          <line x1="12" y1="18" x2="12.01" y2="18"/>
        </svg>
        <span class={styles.text}>100% Responsive</span>
      </div>
      
      <div class={styles.benefit}>
        <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
        <span class={styles.text}>Optimizado para velocidad</span>
      </div>
      
      <div class={styles.benefit}>
        <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span class={styles.text}>Soporte incluido 30 días</span>
      </div>
    </div>
  </div>
</section>
