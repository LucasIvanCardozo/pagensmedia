---
import styles from './ContactCTA.module.css';
---

<section class={`section ${styles.cta}`} id="contacto">
  <div class={styles.orb1}></div>
  <div class={styles.orb2}></div>
  <div class={styles.orb3}></div>
  
  <div class={styles.container}>
    <h2 class={styles.title}>
      ¿Listo para <span>Transformar</span> tu Presencia Digital?
    </h2>
    
    <p class={styles.subtitle}>
      Agenda una consulta gratuita de 30 minutos. Analizamos tu situación actual y te mostramos exactamente cómo podemos ayudarte a alcanzar tus objetivos.
    </p>
    
    <a href="mailto:hola@pagensmedia.com" class={styles.ctaButton}>
      Agenda tu Consulta Gratis
    </a>
    
    <div class={styles.trustSignals}>
      <span class={styles.trustSignal}>
        <svg class={styles.check} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Sin compromiso
      </span>
      <span class={styles.trustSignal}>
        <svg class={styles.check} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Respuesta en 24 horas
      </span>
      <span class={styles.trustSignal}>
        <svg class={styles.check} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        Propuesta personalizada
      </span>
    </div>
    
    <div class={styles.contactOptions}>
      <a href="mailto:hola@pagensmedia.com" class={styles.contactOption}>
        <svg class={styles.contactIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        hola@pagensmedia.com
      </a>
      <a href="https://instagram.com/pagensmedia" target="_blank" rel="noopener noreferrer" class={styles.contactOption}>
        <svg class={styles.contactIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        @pagensmedia
      </a>
    </div>
  </div>
</section>
