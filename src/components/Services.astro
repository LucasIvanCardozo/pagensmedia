---
import styles from './Services.module.css';

const services = [
  {
    icon: 'target',
    title: 'Landing Pages que Venden',
    description: 'Diseñamos páginas de aterrizaje estratégicamente creadas para convertir visitantes en clientes. Cada elemento está optimizado para maximizar tus conversiones.',
    benefits: [
      'Copy persuasivo que conecta con tu audiencia',
      'Formularios optimizados para mayor tasa de respuesta',
      'A/B testing incluido para mejorar resultados'
    ]
  },
  {
    icon: 'building',
    title: 'Sitios Web Profesionales',
    description: 'Presencia digital que refleja la calidad de tu marca. Sitios web corporativos que comunican profesionalismo y generan confianza desde el primer clic.',
    benefits: [
      'Diseño que refuerza tu identidad de marca',
      'Estructura clara que guía a tus visitantes',
      'SEO técnico integrado desde el inicio'
    ]
  },
  {
    icon: 'layout',
    title: 'Paneles de Administración',
    description: 'Interfaces internas que simplifican la gestión de tu negocio. Dashboards intuitivos que permiten a tu equipo trabajar de manera más eficiente.',
    benefits: [
      'Visualización clara de métricas importantes',
      'Flujos de trabajo optimizados',
      'Accesible desde cualquier dispositivo'
    ]
  },
  {
    icon: 'refresh',
    title: 'Renovación Digital Completa',
    description: 'Transformamos sitios web desactualizados en experiencias modernas y efectivas. Mantenemos lo que funciona y mejoramos lo que no.',
    benefits: [
      'Auditoría completa del sitio actual',
      'Migración sin pérdida de SEO',
      'Diseño actualizado que refleja tu evolución'
    ]
  },
  {
    icon: 'home',
    title: 'Webs para Hoteles',
    description: 'Sitios que capturan la esencia de tu hotel y aumentan reservas directas. Experiencias visuales que inspiran confianza y deseo de hospedarse contigo.',
    benefits: [
      'Galerías inmersivas de alta calidad',
      'Integración con booking y calendarios',
      'Optimizado para reservas directas'
    ]
  },
  {
    icon: 'key',
    title: 'Webs para Inmobiliarias',
    description: 'Plataformas de listado que destacan tus propiedades y captan leads calificados. Diseño que comunica confianza y profesionalismo en cada propiedad.',
    benefits: [
      'Listados de propiedades optimizados',
      'Sistema de captación de leads integrado',
      'Mapas interactivos y filtros avanzados'
    ]
  }
];
---

<section class={`section ${styles.services}`} id="servicios">
  <div class={styles.container}>
    <div class={styles.sectionHeader}>
      <p class={styles.label}>Nuestros Servicios</p>
      <h2 class={styles.title}>Soluciones digitales diseñadas para hacer crecer tu negocio</h2>
    </div>
    
    <div class={styles.grid}>
      {services.map((service) => (
        <div class={styles.card}>
          <div class={styles.iconWrapper}>
            {service.icon === 'target' && (
              <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="6"/>
                <circle cx="12" cy="12" r="2"/>
              </svg>
            )}
            {service.icon === 'building' && (
              <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 21h18M5 21V7l8-4 8 4v14M8 21v-5a2 2 0 0 1 4 0v5"/>
              </svg>
            )}
            {service.icon === 'layout' && (
              <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <line x1="3" y1="9" x2="21" y2="9"/>
                <line x1="9" y1="21" x2="9" y2="9"/>
              </svg>
            )}
            {service.icon === 'refresh' && (
              <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23 4 23 10 17 10"/>
                <polyline points="1 20 1 14 7 14"/>
                <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
              </svg>
            )}
            {service.icon === 'home' && (
              <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            )}
            {service.icon === 'key' && (
              <svg class={styles.icon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
              </svg>
            )}
          </div>
          <h3 class={styles.cardTitle}>{service.title}</h3>
          <p class={styles.cardDescription}>{service.description}</p>
          <ul class={styles.benefits}>
            {service.benefits.map((benefit) => (
              <li class={styles.benefit}>{benefit}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
